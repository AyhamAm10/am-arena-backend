{
  "name": "am-arena-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "migration": "typeorm-ts-node-commonjs migration:run -d ./src/config/data_source.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate ./src/migrations/test -d ./src/config/data_source.ts",
    "migration:prod": "typeorm migration:run -d ./build/config/data_source.js",
    "schema:drop": "typeorm-ts-node-commonjs schema:drop -d ./src/config/data_source.ts",
    "schema:sync": "typeorm-ts-node-commonjs schema:sync -d ./src/config/data_source.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
